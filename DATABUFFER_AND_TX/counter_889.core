CAPI=2:
name: "u337mg235:ece337:counter_889:1.0.0"
description: ""

filesets:
    rtl:
        files:
            - "source/counter_889.sv"
        file_type: systemVerilogSource
        depend:
        #     - "fusesoc:core:name"
            - "u337mg235:ece337:flex_counter:1.0.0"

    synth:
        depend:
            - "ece337:tech:AMI_05_LIB"
            - "u337mg235:ece337:counter_889_syn"
            - "u337mg235:ece337:flex_counter:1.0.0"

    tb:
        files:
            - "testbench/tb_counter_889.sv"
            - "waves/counter_889.do": { file_type: user }
            - "waves/counter_889.gtkw": { file_type: user }
            # - "data/file.txt": { file_type: user }
        file_type: systemVerilogSource
        depend:
            - "u337mg235:ece337:questafiles"
            - "u337mg235:ece337:flex_counter:1.0.0"

    synfiles:
        files:
            - "scripts/syn_counter_889.tcl"
        file_type: tclSource
        depend:
            - "u337mg235:ece337:synfiles"

targets:
    default: &default
        filesets:
            - rtl
        toplevel: counter_889

    sim: &sim
        <<: *default
        default_tool: verilator
        filesets_append:
            - tb
        toplevel: tb_counter_889
        tools:
            modelsim:
                vsim_options:
                    - -vopt
                    - -voptargs='+acc'
                    - -t ps
                    - -do "source waves.tcl ; load_wave waves/counter_889.do"
                    - -onfinish stop
                    - -do "set PrefSource(OpenOnFinish) 0 ; set PrefMain(LinePrefix) \"\" ; set PrefMain(colorizeTranscript) 1"
                    - -coverage
                vlog_options:
                    - +cover
            verilator:
                verilator_options:
                    - --cc
                    - --trace
                    - --main
                    - --timing
                    - --coverage
                make_options:
                    - -j

    lint:
        <<: *default
        default_tool: verilator
        filesets_append:
            - tb
        tools:
            verilator:
                mode: lint-only
                verilator_options:
                    - --timing
                    - -Wall

    syn:
        <<: *default
        filesets_append:
            - synfiles
        default_tool: design_compiler
        toplevel: counter_889
        tools:
            design_compiler:
                script_dir: "src/u337mg235_ece337_synfiles_0"
                dc_script: "synth.tcl"
                report_dir: "reports"
                target_library: "/home/ecegrid/a/ece337/summer24-refactor/tech/ami05/osu05_stdcells.db"
                libs: "/home/ecegrid/a/ece337/summer24-refactor/tech/ami05/osu05_stdcells.db dw_foundation.sldb"

    syn_sim:
        <<: *sim
        filesets:
            - synth
            - tb

